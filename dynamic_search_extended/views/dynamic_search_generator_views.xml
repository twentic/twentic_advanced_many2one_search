<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================================== -->
    <!-- List view                                                           -->
    <!-- ================================================================== -->
    <record id="view_dynamic_search_generator_list" model="ir.ui.view">
        <field name="name">dynamic.search.generator.list</field>
        <field name="model">dynamic.search.generator</field>
        <field name="arch" type="xml">
            <list string="Dynamic Search Generators" decoration-success="state == 'active'" decoration-muted="state == 'draft'">
                <field name="name"/>
                <field name="model_id"/>
                <field name="model_name" optional="hide"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'active'"
                       decoration-warning="state == 'draft'"/>
            </list>
        </field>
    </record>

    <!-- ================================================================== -->
    <!-- Form view                                                           -->
    <!-- ================================================================== -->
    <record id="view_dynamic_search_generator_form" model="ir.ui.view">
        <field name="name">dynamic.search.generator.form</field>
        <field name="model">dynamic.search.generator</field>
        <field name="arch" type="xml">
            <form string="Dynamic Search Generator">
                <header>
                    <button name="action_create_search_filters"
                            string="Create Search Filters"
                            type="object"
                            class="btn-primary"
                            invisible="state == 'active'"/>
                    <button name="action_remove_search_filters"
                            string="Remove Search Filters"
                            type="object"
                            class="btn-danger"
                            invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,active"/>
                </header>

                <sheet>
                    <group>
                        <group>
                            <field name="model_id"
                                   options="{'no_create': True, 'no_open': True}"
                                   readonly="state == 'active'"/>
                            <field name="name" placeholder="e.g. Sale Order Extra Filters"/>
                            <field name="model_name" invisible="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Search Lines" name="search_lines">
                            <field name="line_ids"
                                   readonly="state == 'active'"
                                   widget="one2many">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="model_technical_name" column_invisible="1"/>
                                    <field name="field_expression"
                                           widget="field_expression_selector"/>
                                    <field name="is_deployed"
                                           widget="boolean_toggle" readonly="1"/>
                                    <field name="view_id" optional="hide" readonly="1"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ================================================================== -->
    <!-- Search view                                                         -->
    <!-- ================================================================== -->
    <record id="view_dynamic_search_generator_search" model="ir.ui.view">
        <field name="name">dynamic.search.generator.search</field>
        <field name="model">dynamic.search.generator</field>
        <field name="arch" type="xml">
            <search string="Dynamic Search Generators">
                <field name="name"/>
                <field name="model_id"/>
                <separator/>
                <filter string="Draft" name="draft"
                        domain="[('state', '=', 'draft')]"/>
                <filter string="Active" name="active"
                        domain="[('state', '=', 'active')]"/>
                <group expand="0" string="Group By">
                    <filter string="Model" name="groupby_model"
                            context="{'group_by': 'model_id'}"/>
                    <filter string="State" name="groupby_state"
                            context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ================================================================== -->
    <!-- Action                                                              -->
    <!-- ================================================================== -->
    <record id="action_dynamic_search_generator" model="ir.actions.act_window">
        <field name="name">Dynamic Search Generators</field>
        <field name="res_model">dynamic.search.generator</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_dynamic_search_generator_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first dynamic search configuration
            </p>
            <p>
                Select a model and define field expressions to add custom
                search filters to that model's search bar.
            </p>
        </field>
    </record>

</odoo>
